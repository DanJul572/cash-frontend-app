{
    "plugins": ["@trivago/prettier-plugin-sort-imports"],
    "importOrder": [
        "^react$",
        "^react-(.*)$",
        "<THIRD_PARTY_MODULES>",
        "^@mui/material",
        "^@mui/material/(.*)$",
        "^@mui/icons-material/(.*)$",
        "^@mui/x-tree-view",
        "^@fontsource/(.*)$",
        "^@(.*)$",
        "^@assets/(.*)$",
        "^@components/(.*)$",
        "^@configs/(.*)$",
        "^@constants/(.*)$",
        "^@endpoints/(.*)$",
        "^@features/(.*)$",
        "^@instances/(.*)$",
        "^@hooks/(.*)$",
        "^@layouts/(.*)$",
        "^@locales/(.*)$",
        "^@mappers/(.*)$",
        "^@queries/(.*)$",
        "^@requests/(.*)$",
        "^@schemas/(.*)$",
        "^@styles/(.*)$",
        "^@types/(.*)$",
        "^@utils/(.*)$",
        "^[./]"
    ],
    "singleQuote": true,
    "importOrderSeparation": true,
    "printWidth": 100,
    "tabWidth": 4
}
