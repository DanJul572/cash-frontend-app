{
    "name": "cash-app",
    "private": false,
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.es.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite --config vite.app.config.ts",
        "build:app": "tsc -b && vite build --config vite.app.config.ts",
        "build:lib": "tsc -b && vite build --config vite.lib.config.ts",
        "preview": "vite preview --config vite.app.config.ts",
        "prepublishOnly": "pnpm build:lib",
        "test": "vitest --globals",
        "test:coverage": "vitest --globals --coverage",
        "update:deps": "ncu -u --cooldown 1",
        "prepare": "husky",
        "lint": "eslint .",
        "format": "prettier . --write",
        "publish:verdaccio": "node publish.cjs"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/roboto": "^5.2.10",
        "@hookform/resolvers": "^5.4.0",
        "@mui/icons-material": "^9.1.1",
        "@mui/material": "^9.1.1",
        "@mui/x-charts": "^9.6.0",
        "@mui/x-data-grid": "^9.6.0",
        "@mui/x-date-pickers": "^9.6.0",
        "@mui/x-tree-view": "^9.6.0",
        "@tanstack/react-query": "^5.101.0",
        "@tanstack/react-query-devtools": "^5.101.0",
        "@tanstack/react-router": "^1.170.16",
        "@tanstack/react-router-devtools": "^1.167.0",
        "axios": "^1.18.0",
        "dayjs": "^1.11.21",
        "i18next": "^26.3.1",
        "pnpm": "11.8.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-hook-form": "^7.80.0",
        "react-i18next": "^17.0.8",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@eslint/js": "^10.0.1",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tanstack/router-cli": "^1.167.17",
        "@tanstack/router-plugin": "^1.168.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/babel__core": "^7.20.5",
        "@types/node": "^26.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "4.1.9",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.5.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "msw": "^2.14.6",
        "npm-check-updates": "^22.2.7",
        "prettier": "3.8.4",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^5.0.2",
        "vitest": "^4.1.9"
    },
    "packageManager": "pnpm@11.8.0",
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
